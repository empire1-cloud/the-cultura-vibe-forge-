app = FastAPI(title="Cultura Vibe Engine")

# --- Constants & Limits ---
RATE_HOUR_SECONDS = 3600
RATE_DAY_SECONDS = 86400
TIER_LIMITS = {
    "aprendiz": {"hour": 20, "day": 50, "concurrent": 2},
    "maestro": {"hour": 200, "day": 10000, "concurrent": 5},
}

# --- Subscription Helper ---
def _get_or_create_maestro_price():
    id_key = "cultura_maestro_monthly_v1"
    try:
        prices = stripe.Price.list(lookup_keys=[id_key], limit=1)
        if prices.data:
            return prices.data[0].id
        product = stripe.Product.create(
            name="CULTURA Maestro Monthly Pass",
            description="Elite Fabrication Shop pass. Full Vibe. Con Ganas.",
            metadata={"SOULFIRE_STD": "V1"}
        )
        price = stripe.Price.create(
            product=product.id,
            unit_amount=1900,
            currency="usd",
            recurring={"interval": "month"},
            lookup_key=id_key,
            transfer_lookup_key=True
        )
        return price.id
    except Exception as e:
        logger.error(f"Stripe initialization failed: {e}")
        return None

MAESTRO_PRICE_ID = _get_or_create_maestro_price()

# --- Security Utils ---
def hash_password(password: str) -> str:
    return pwd_context.hash(password)

def verify_password(plain_password: str, hashed_password: str) -> bool:
    return pwd_context.verify(plain_password, hashed_password)

def make_token(user_id: str) -> str:
    payload = {"sub": user_id, "exp": datetime.now(timezone.utc) + timedelta(days=7)}
    return jwt.encode(payload, JWT_SECRET, algorithm=JWT_ALGORITHM)

async def current_user(request: Request) -> dict:
    auth_header = request.headers.get("Authorization")
    if not auth_header or not auth_header.startswith("Bearer "):
        raise HTTPException(status_code=401, detail="Unauthorized")
    token = auth_header.split(" ")[1]
    try:
        payload = jwt.decode(token, JWT_SECRET, algorithms=[JWT_ALGORITHM])
        user = await db.users.find_one({"id": payload["sub"]}, {"_id": 0, "password_hash": 1, "id": 1, "email": 1, "tier": 1, "tier_until": 1, "display_name": 1})
        if not user: raise HTTPException(status_code=401)
        return user
    except: raise HTTPException(status_code=401)

# --- Schemas ---
class SignupIn(BaseModel):
    email: EmailStr
    password: str
    display_name: str

class LoginIn(BaseModel):
    email: EmailStr
    password: str

class UserOut(BaseModel):
    id: str
    email: str
    display_name: str

class AuthOut(BaseModel):
    token: str
    user: UserOut

class GenerateIn(BaseModel):
    prompt: str
    category: str
    title: Optional[str] = None

class CodeFile(BaseModel):
    path: str
    content: str

class Artifact(BaseModel):
    id: str
    user_id: str
    title: str
    description: str
    category: str
    prompt: str
    refined_prompt: str
    files: List[CodeFile]
    terminal_log: List[str]
    created_at: str

class UsageOut(BaseModel):
    tier: str
    credits_remaining: int
    concurrent_usage: int
    forges_hour_used: int
    forges_hour_limit: int
    is_critical_hour: bool
    upgrade_path: str

# --- Internal Helpers ---
async def _usage_counts(user_id: str) -> dict:
    now = datetime.now(timezone.utc)
    hour_cutoff = now - timedelta(hours=1)
    hour_used = await db.rate_events.count_documents({"user_id": user_id, "ts": {"$gte": hour_cutoff}})
    return {"hour_used": hour_used}

def _user_tier(user: dict) -> str:
    tier = user.get("tier") or "aprendiz"
    until = user.get("tier_until")
    if tier == "maestro" and until:
        if datetime.fromisoformat(until) < datetime.now(timezone.utc):
            return "aprendiz"
    return tier

# --- Routes: Auth ---
@app.post("/auth/signup", response_model=AuthOut)
async def signup(payload: SignupIn):
    existing = await db.users.find_one({"email": payload.email.lower()})
    if existing: raise HTTPException(status_code=409, detail="Email taken")
    user_id = str(uuid.uuid4())
    doc = {
        "id": user_id, "email": payload.email.lower(), "display_name": payload.display_name.strip(),
        "password_hash": hash_password(payload.password), "tier": "aprendiz", "tier_until": None,
        "created_at": datetime.now(timezone.utc).isoformat(),
    }
    await db.users.insert_one(doc)
    return AuthOut(token=make_token(user_id), user=UserOut(id=user_id, email=doc["email"], display_name=doc["display_name"]))

@app.post("/auth/login", response_model=AuthOut)
async def login(payload: LoginIn):
    user = await db.users.find_one({"email": payload.email.lower()})
    if not user or not verify_password(payload.password, user["password_hash"]):
        raise HTTPException(status_code=401, detail="Invalid credentials")
    return AuthOut(token=make_token(user["id"]), user=UserOut(id=user["id"], email=user["email"], display_name=user["display_name"]))

# --- Routes: Billing & Usage ---
@app.get("/billing/packages")
async def list_packages():
    return [{
        "id": "maestro_subscription", "mode": "subscription", "price_amount": 1900,
        "name": "Maestro Pass (Monthly)", "tier": "maestro", "description": "Recurring Empire access. 200/hr. Full Vibe."
    }]

@app.get("/billing/usage", response_model=UsageOut)
async def get_usage(user: dict = Depends(current_user)):
    tier = _user_tier(user)
    limit = TIER_LIMITS[tier]["hour"]
    counts = await _usage_counts(user["id"])
    return UsageOut(
        tier=tier, credits_remaining=50, concurrent_usage=0, 
        forges_hour_used=counts["hour_used"], forges_hour_limit=limit,
        is_critical_hour=(counts["hour_used"] >= (limit * 0.8)), upgrade_path="/billing"
    )

# --- Routes: The Forge (Streaming) ---
@app.post("/artifacts/generate-stream")
async def generate_artifact_stream(payload: GenerateIn, user: dict = Depends(current_user)):
    user_id = user["id"]
    tier = _user_tier(user)
    limit = TIER_LIMITS[tier]["hour"]
    
    async def event_generator():
        counts = await _usage_counts(user_id)
        yield f"data: {json.dumps({'event': 'log', 'msg': '> arquitecto init --soulfire'})}\n\n"
        
        if counts["hour_used"] >= (limit * 0.8):
            nudge = {"event": "log", "msg": "[forge_meter] Hourly cap nearing capacity. Hustle accordingly.", "type": "system_nudge"}
            yield f"data: {json.dumps(nudge)}\n\n"
            await asyncio.sleep(0.3)

        # Mocking LLM Forge Logic for brief demo
        artifact_id = str(uuid.uuid4())
        yield f"data: {json.dumps({'event': 'log', 'msg': '[forge] Calling Claude Sonnet 4.5...'})}\n\n"
        await asyncio.sleep(1)
        yield f"data: {json.dumps({'event': 'done', 'id': artifact_id, 'title': 'Project Forged'})}\n\n"

    return StreamingResponse(event_generator(), media_type="text/event-stream")

